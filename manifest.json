{
  "manifest_version": 3,
  "name": "Fennec Update Notifier",
  "version": "1.0.0",
  "description": "Notifies you when a new version of Fennec is available.",
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://api.github.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_icon": "icons/fennec-48.png",
    "default_title": "Fennec Update Notifier",
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icons/fennec-48.png",
    "96": "icons/fennec-96.png"
  }
}
